{
  "schema_version": 1,
  "comment": "v5 per-project-shape command routing. Loaded by project-shape-detection.md + verification-gates.md + first-run-bootstrap.md. Each shape maps detector signals -> default commands for the 6 cross-shape gate rows (test/lint/build/license/sbom/fresh_install_smoke).",
  "shapes": {
    "python": {
      "source_paths": ["packages/*/src/", "src/"],
      "test_paths": ["tests/"],
      "test": "uv run pytest -q || pytest -q",
      "lint": "uv run ruff check && uv run mypy --strict packages/",
      "format_check": "uv run ruff format --check",
      "build": "uv build --all-packages || python -m build",
      "license": "pip-licenses --format=json",
      "sbom": "cyclonedx-py environment -o sbom.cdx.json --of JSON --sv 1.6",
      "fresh_install_smoke": "python -m venv /tmp/fresh-{VER} && /tmp/fresh-{VER}/bin/pip install '{PKG}=={VER}' && /tmp/fresh-{VER}/bin/{BIN} --version",
      "version_extract": "python -c 'import tomllib; print(tomllib.load(open(\"pyproject.toml\",\"rb\"))[\"project\"][\"version\"])'",
      "version_files": ["pyproject.toml", "packages/*/pyproject.toml"]
    },
    "node": {
      "source_paths": ["packages/*/src/", "apps/*/src/", "src/"],
      "test_paths": ["tests/", "__tests__/", "packages/*/tests/", "packages/*/__tests__/"],
      "test": "pnpm test || yarn test || npm test",
      "lint": "pnpm lint && pnpm exec tsc --noEmit",
      "format_check": "pnpm exec prettier --check .",
      "build": "pnpm build || yarn build || npm run build",
      "license": "license-checker --json",
      "sbom": "cyclonedx-npm --output-file sbom.cdx.json --output-format JSON --spec-version 1.6",
      "fresh_install_smoke": "npm install -g {PKG}@{VER} && {BIN} --version",
      "version_extract": "node -e 'console.log(require(\"./package.json\").version)'",
      "version_files": ["package.json", "packages/*/package.json", "apps/*/package.json"]
    },
    "rust": {
      "source_paths": ["crates/*/src/", "src/"],
      "test_paths": ["tests/", "crates/*/tests/"],
      "test": "cargo test --workspace",
      "lint": "cargo clippy --all-targets --workspace -- -D warnings && cargo fmt --check",
      "format_check": "cargo fmt --check",
      "build": "cargo build --release --workspace",
      "license": "cargo license --json",
      "sbom": "cargo cyclonedx --format json",
      "fresh_install_smoke": "cargo install {PKG} --version {VER} && {BIN} --version",
      "version_extract": "python -c 'import tomllib; print(tomllib.load(open(\"Cargo.toml\",\"rb\"))[\"package\"][\"version\"])'",
      "version_files": ["Cargo.toml", "crates/*/Cargo.toml"]
    },
    "go": {
      "source_paths": ["./", "cmd/", "internal/", "pkg/"],
      "test_paths": ["./..."],
      "test": "go test ./...",
      "lint": "go vet ./... && golangci-lint run",
      "format_check": "test -z $(gofmt -l .)",
      "build": "go build ./...",
      "license": "go-licenses report ./... --template '{{range .}}{{.Name}},{{.LicenseName}}\\n{{end}}'",
      "sbom": "cyclonedx-gomod mod -output sbom.cdx.json -json",
      "fresh_install_smoke": "go install {PKG}@{VER} && {BIN} --version",
      "version_extract": "git describe --tags --abbrev=0",
      "version_files": ["go.mod"]
    },
    "java-maven": {
      "source_paths": ["src/main/java/", "*/src/main/java/"],
      "test_paths": ["src/test/java/", "*/src/test/java/"],
      "test": "mvn test",
      "lint": "mvn checkstyle:check spotbugs:check",
      "format_check": "mvn spotless:check",
      "build": "mvn package -DskipTests",
      "license": "mvn license:aggregate-third-party-report",
      "sbom": "mvn org.cyclonedx:cyclonedx-maven-plugin:makeAggregateBom",
      "fresh_install_smoke": "mvn dependency:get -Dartifact={PKG}:{VER}",
      "version_extract": "mvn help:evaluate -Dexpression=project.version -q -DforceStdout",
      "version_files": ["pom.xml", "*/pom.xml"]
    },
    "java-gradle": {
      "source_paths": ["src/main/java/", "*/src/main/java/", "src/main/kotlin/"],
      "test_paths": ["src/test/java/", "*/src/test/java/"],
      "test": "gradle test",
      "lint": "gradle check",
      "format_check": "gradle spotlessCheck",
      "build": "gradle build -x test",
      "license": "gradle generateLicenseReport",
      "sbom": "gradle cyclonedxBom",
      "fresh_install_smoke": "gradle dependencies",
      "version_extract": "gradle properties -q | grep '^version:' | awk '{print $2}'",
      "version_files": ["build.gradle", "build.gradle.kts", "gradle.properties"]
    },
    "ruby": {
      "source_paths": ["lib/", "app/"],
      "test_paths": ["spec/", "test/"],
      "test": "bundle exec rspec || bundle exec rake test",
      "lint": "bundle exec rubocop",
      "format_check": "bundle exec rubocop",
      "build": "gem build *.gemspec",
      "license": "bundle exec license_finder report --format=json",
      "sbom": "cyclonedx-ruby",
      "fresh_install_smoke": "gem install {PKG} -v {VER} && {BIN} --version",
      "version_extract": "ruby -e 'require_relative \"lib/{PKG}/version\"; puts {PKG}::VERSION'",
      "version_files": ["lib/*/version.rb", "Gemfile"]
    },
    "elixir": {
      "source_paths": ["lib/", "apps/*/lib/"],
      "test_paths": ["test/", "apps/*/test/"],
      "test": "mix test",
      "lint": "mix credo --strict && mix dialyzer",
      "format_check": "mix format --check-formatted",
      "build": "mix compile --warnings-as-errors",
      "license": "mix licenses",
      "sbom": "mix sbom.cyclonedx",
      "fresh_install_smoke": "mix archive.install hex {PKG} {VER}",
      "version_extract": "mix run -e 'IO.puts Mix.Project.config[:version]'",
      "version_files": ["mix.exs"]
    },
    "php": {
      "source_paths": ["src/", "lib/"],
      "test_paths": ["tests/"],
      "test": "vendor/bin/phpunit || vendor/bin/pest",
      "lint": "vendor/bin/phpstan analyse --level=8 && vendor/bin/php-cs-fixer fix --dry-run",
      "format_check": "vendor/bin/php-cs-fixer fix --dry-run --diff",
      "build": "composer install --no-dev --optimize-autoloader",
      "license": "composer licenses --format=json",
      "sbom": "composer make-bom --output-format=JSON",
      "fresh_install_smoke": "composer require {PKG}={VER}",
      "version_extract": "php -r 'echo json_decode(file_get_contents(\"composer.json\"))->version;'",
      "version_files": ["composer.json"]
    },
    "dotnet": {
      "source_paths": ["src/", "*/src/"],
      "test_paths": ["tests/", "*/tests/"],
      "test": "dotnet test",
      "lint": "dotnet format --verify-no-changes",
      "format_check": "dotnet format --verify-no-changes",
      "build": "dotnet build --configuration Release",
      "license": "dotnet-project-licenses --input . --json",
      "sbom": "dotnet CycloneDX -j",
      "fresh_install_smoke": "dotnet tool install -g {PKG} --version {VER} && {BIN} --version",
      "version_extract": "dotnet-script -e 'Console.WriteLine(GetType().Assembly.GetName().Version)'",
      "version_files": ["*.csproj", "Directory.Build.props"]
    },
    "python-rust-hybrid": {
      "comment": "maturin-style projects with Python wrapper around Rust core. Runs both sides of the test/lint/build gate.",
      "source_paths": ["python/", "src/", "crates/*/src/"],
      "test_paths": ["tests/"],
      "test": "uv run pytest -q && cargo test --workspace",
      "lint": "uv run ruff check && uv run mypy --strict && cargo clippy --all-targets -- -D warnings",
      "format_check": "uv run ruff format --check && cargo fmt --check",
      "build": "maturin build --release",
      "license": "pip-licenses --format=json && cargo license --json",
      "sbom": "cyclonedx-py environment -o sbom-python.cdx.json && cargo cyclonedx --format json",
      "fresh_install_smoke": "python -m venv /tmp/fresh-{VER} && /tmp/fresh-{VER}/bin/pip install '{PKG}=={VER}'",
      "version_extract": "python -c 'import tomllib; print(tomllib.load(open(\"pyproject.toml\",\"rb\"))[\"project\"][\"version\"])'",
      "version_files": ["pyproject.toml", "Cargo.toml"]
    }
  },
  "interpolation_tokens": {
    "{VER}": "Current target version per pyproject.toml / package.json / Cargo.toml etc.",
    "{PKG}": "Package name per the project's primary publishable artifact",
    "{BIN}": "Binary name for CLI smoke-test (often equal to {PKG} but not always — operator confirms at first run)"
  }
}
